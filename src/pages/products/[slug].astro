---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductGallery from '@/components/ProductGallery.astro';
import WhatsAppButton from '@/components/WhatsAppButton.astro';
import Badge from '@/components/Badge.astro';
import { formatPrice, generateProductSchema, generateSEO, getProductBadges, toAbsoluteUrl } from '@/utils/helpers';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

type Props = {
  product: CollectionEntry<'products'>;
};

const { product } = Astro.props;
const { data } = product;
const { Content } = await render(product);

const badges = getProductBadges(data);
const price = formatPrice(data.price, data.currency);

// Generate SEO data
const seo = generateSEO({
  title: data.seo?.title || `${data.title} - Handmade Indian Craft`,
  description: data.seo?.description || data.short,
  image: data.images?.[0] || '/images/og-default.png',
  type: 'product',
});

// Determine if product is available
const isAvailable = data.in_stock !== false;
const productSchema = generateProductSchema({
  ...data,
  url: `/products/${product.id}`,
});

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: toAbsoluteUrl('/'),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Shop',
      item: toAbsoluteUrl('/shop'),
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: data.title,
      item: toAbsoluteUrl(`/products/${product.id}/`),
    },
  ],
};
---

<BaseLayout seo={seo}>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="inline-flex items-center text-sm font-medium text-neutral-700 hover:text-primary-600  ">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Home
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 text-neutral-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <a href="/shop" class="ml-1 text-sm font-medium text-neutral-700 hover:text-primary-600 md:ml-2  ">Shop</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-neutral-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-neutral-500 md:ml-2 ">{data.title}</span>
          </div>
        </li>
      </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
      <!-- Product Gallery -->
      <div class="space-y-4">
        <ProductGallery images={data.images} title={data.title} />
      </div>

      <!-- Product Info -->
      <div class="space-y-6">
        <!-- Badges -->
        <Badge badges={badges} size="sm" />

        <!-- Title -->
        <div>
          <h1 class="text-2xl md:text-3xl lg:text-4xl font-serif font-bold text-neutral-900  mb-2">
            {data.title}
          </h1>
          <p class="text-lg text-neutral-600 ">
            {data.short}
          </p>
        </div>

        <!-- Price -->
        <div class="flex items-center space-x-4">
          <span class="text-3xl font-bold text-primary-600">
            {price}
          </span>
          <span class="text-sm text-neutral-500 ">
            SKU: {data.sku}
          </span>
        </div>

        <!-- Stock Status -->
        <div class="flex items-center space-x-2">
          <div class={`w-3 h-3 rounded-full ${isAvailable ? 'bg-green-500' : 'bg-red-500'}`}></div>
          <span class={`text-sm font-medium ${isAvailable ? 'text-green-600' : 'text-red-600'}`}>
            {isAvailable ? 'In Stock' : 'Out of Stock'}
          </span>
        </div>

        <!-- Categories and Tags -->
        <div class="space-y-3">
          <div>
            <span class="text-sm font-medium text-neutral-700 ">Categories:</span>
            <div class="flex flex-wrap gap-2 mt-1">
              {data.categories.map((category: string) => (
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary-100 text-primary-800  ">
                  {category}
                </span>
              ))}
            </div>
          </div>
          
          <div>
            <span class="text-sm font-medium text-neutral-700 ">Tags:</span>
            <div class="flex flex-wrap gap-2 mt-1">
              {data.tags.map((tag: string) => (
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-neutral-100 text-neutral-800  ">
                  #{tag}
                </span>
              ))}
            </div>
          </div>
        </div>

        <!-- Specifications -->
        {data.specs && (
          <div class="border-t border-neutral-200  pt-6">
            <h3 class="text-lg font-semibold text-neutral-900  mb-4">
              Specifications
            </h3>
            <dl class="grid grid-cols-1 gap-3">
              {data.specs.material && (
                <div class="flex justify-between">
                  <dt class="text-sm font-medium text-neutral-700 ">Material:</dt>
                  <dd class="text-sm text-neutral-900 ">{data.specs.material}</dd>
                </div>
              )}
              {data.specs.size && (
                <div class="flex justify-between">
                  <dt class="text-sm font-medium text-neutral-700 ">Size:</dt>
                  <dd class="text-sm text-neutral-900 ">{data.specs.size}</dd>
                </div>
              )}
              {data.specs.weight && (
                <div class="flex justify-between">
                  <dt class="text-sm font-medium text-neutral-700 ">Weight:</dt>
                  <dd class="text-sm text-neutral-900 ">{data.specs.weight}</dd>
                </div>
              )}
              {data.specs.care && (
                <div class="flex justify-between">
                  <dt class="text-sm font-medium text-neutral-700 ">Care:</dt>
                  <dd class="text-sm text-neutral-900 ">{data.specs.care}</dd>
                </div>
              )}
            </dl>
          </div>
        )}

        <!-- WhatsApp Order Button -->
        <div class="border-t border-neutral-200  pt-6">
          {isAvailable ? (
            <WhatsAppButton 
              product={{
                ...data,
                url: `/products/${product.id}`
              }}
              variant="large"
              className=""
            />
          ) : (
            <div class="text-center">
              <button 
                disabled 
                class="w-full px-8 py-4 text-lg bg-neutral-400 text-white rounded-xl cursor-not-allowed"
              >
                Out of Stock
              </button>
              <p class="text-sm text-neutral-500  mt-2">
                This item is currently out of stock. Contact us for availability.
              </p>
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Product Description -->
    <div class="mt-12 border-t border-neutral-200  pt-8">
      <h2 class="text-2xl font-serif font-semibold text-neutral-900  mb-6">
        Product Description
      </h2>
      <div class="prose prose-neutral  max-w-none">
        <Content />
      </div>
    </div>
  </div>

  <!-- Structured Data -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
