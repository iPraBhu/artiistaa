---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductCard from '@/components/ProductCard.astro';
import { generateSEO, slugify, toAbsoluteUrl } from '@/utils/helpers';

interface CategoryProduct {
  url: string;
  slug: string;
  title: string;
  sku: string;
  price: number;
  currency: string;
  categories: string[];
  tags: string[];
  images: string[];
  short: string;
  in_stock?: boolean;
  featured?: boolean;
  bestseller?: boolean;
  limited?: boolean;
  new?: boolean;
  specs?: {
    material?: string;
    size?: string;
    weight?: string;
    care?: string;
  };
}

export async function getStaticPaths() {
  const products = await getCollection('products');
  const categoryMap = new Map<string, { name: string; products: CategoryProduct[] }>();

  products.forEach((product) => {
    product.data.categories.forEach((category: string) => {
      const slug = slugify(category);
      const existingEntry = categoryMap.get(slug);
      const categoryProduct: CategoryProduct = {
        ...product.data,
        slug: product.id,
        url: `/products/${product.id}`,
      };

      if (existingEntry) {
        existingEntry.products.push(categoryProduct);
        return;
      }

      categoryMap.set(slug, {
        name: category,
        products: [categoryProduct],
      });
    });
  });

  return Array.from(categoryMap.entries()).map(([slug, entry]) => ({
    params: { slug },
    props: {
      categoryName: entry.name,
      products: entry.products,
    },
  }));
}

const { categoryName, products } = Astro.props;

const seo = generateSEO({
  title: `${categoryName} Products`,
  description: `Explore handmade ${categoryName.toLowerCase()} crafted by skilled Indian artisans.`,
  type: 'website',
});

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${categoryName} Products`,
  numberOfItems: products.length,
  itemListElement: products.map((product: CategoryProduct, index: number) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: toAbsoluteUrl(product.url),
    name: product.title,
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: toAbsoluteUrl('/'),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Shop',
      item: toAbsoluteUrl('/shop'),
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: categoryName,
      item: toAbsoluteUrl(`/category/${Astro.params.slug}/`),
    },
  ],
};
---

<BaseLayout seo={seo}>
  <section class="bg-neutral-50  py-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-sm uppercase tracking-wide text-neutral-500 ">Category</p>
        <h1 class="mt-2 text-3xl sm:text-4xl font-serif font-bold text-neutral-900 ">
          {categoryName}
        </h1>
        <p class="mt-3 text-lg text-neutral-600 ">
          {products.length === 1 ? '1 handmade product' : `${products.length} handmade products`}
        </p>
      </div>
    </div>
  </section>

  <section class="py-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      {products.length > 0 ? (
        <div class="products-grid">
          {products.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>
      ) : (
        <div class="max-w-lg mx-auto text-center py-16">
          <h2 class="text-2xl font-semibold text-neutral-900 ">No products yet</h2>
          <p class="mt-3 text-neutral-600 ">This category is being updated. Please check back soon.</p>
          <a href="/shop" class="inline-flex mt-6 px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white rounded-lg font-medium transition-colors">
            Browse All Products
          </a>
        </div>
      )}
    </div>
  </section>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>

<style>
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }

  @media (max-width: 640px) {
    .products-grid {
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 1.5rem;
    }
  }
</style>
