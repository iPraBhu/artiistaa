---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductCard from '@/components/ProductCard.astro';
import SearchBar from '@/components/SearchBar.astro';
import { SITE_CONFIG, WOMEN_EMPOWERMENT, ATMANIRBHAR_MESSAGING } from '@/utils/constants';
import { generateSEO } from '@/utils/helpers';
import { getCollection } from 'astro:content';

// Load featured products from content collection
const allProducts = await getCollection('products');
const featuredProducts = allProducts
  .filter(product => product.data.featured || product.data.bestseller)
  .slice(0, 6)
  .map(product => ({
    ...product.data,
    slug: product.id,
    content: product.body,
    url: `/products/${product.id}`,
  }));

// If no featured products, show first 6 products
if (featuredProducts.length === 0) {
  featuredProducts.push(...allProducts.slice(0, 6).map(product => ({
    ...product.data,
    slug: product.id,
    content: product.body,
    url: `/products/${product.id}`,
  })));
}

// SEO data
const seo = generateSEO({
  title: `${SITE_CONFIG.STORE_NAME} - ${SITE_CONFIG.BRAND_VALUES.womenOwned} | ${SITE_CONFIG.BRAND_VALUES.madeInIndia}`,
  description: SITE_CONFIG.DESCRIPTION,
  type: 'website',
});

// Categories for quick navigation
const categories = [
  {
    name: 'Festive Decor',
    href: '/category/festive-decor',
    icon: '🪔',
    description: 'Traditional diyas, rangoli, and festive items',
    hindi: 'त्योहारी सजावट',
  },
  {
    name: 'Home Decor',
    href: '/category/home-decor',
    icon: '🏺',
    description: 'Beautiful handmade items for your home',
    hindi: 'घर की सजावट',
  },
  {
    name: 'Pottery & Ceramics',
    href: '/category/pottery-and-ceramics',
    icon: '🏺',
    description: 'Handcrafted pottery and ceramic pieces',
    hindi: 'मिट्टी के बर्तन',
  },
  {
    name: 'Textiles & Fabrics',
    href: '/category/textiles-and-fabrics',
    icon: '🧵',
    description: 'Traditional fabrics and textile art',
    hindi: 'वस्त्र और कपड़े',
  },
];
---

<BaseLayout seo={seo}>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-saffron-50 via-white to-emerald-50   ">
    <!-- Indian pattern overlay -->
    <div class="absolute inset-0 bg-mandala opacity-20"></div>
    <div class="absolute inset-0 bg-paisley opacity-10"></div>
    
    <!-- Decorative Indian flag colors accent -->
    <div class="absolute top-0 left-0 w-full h-2 bg-indian-flag"></div>
    
    <div class="relative container mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
      <div class="max-w-6xl mx-auto">
        <!-- Welcome in Hindi -->
        <div class="text-center mb-6">
          <p class="text-3xl sm:text-4xl font-hindi text-saffron-600 mb-2">{SITE_CONFIG.HINDI_WELCOME}</p>
          <p class="text-sm text-emerald-700 font-hindi">{SITE_CONFIG.SANSKRIT_MOTTO}</p>
        </div>
        
        <!-- Main Heading with Indian styling -->
        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-decorative font-bold text-center mb-8">
          <span class="block text-neutral-800 ">Welcome to</span>
          <span class="block bg-gradient-to-r from-saffron-700 via-terracotta-600 to-emerald-700 bg-clip-text text-transparent">
            {SITE_CONFIG.STORE_NAME}
          </span>
        </h1>
        
        <!-- Brand messaging with emphasis on women empowerment -->
        <div class="text-center mb-12">
          <p class="text-xl sm:text-2xl text-neutral-800  mb-4 font-medium">
            {SITE_CONFIG.TAGLINE}
          </p>
          <p class="text-lg text-neutral-700  mb-6 max-w-4xl mx-auto leading-relaxed">
            {SITE_CONFIG.DESCRIPTION}
          </p>
          
          <!-- Women empowerment badges -->
          <div class="flex flex-wrap justify-center gap-3 mb-8">
            <span class="inline-flex items-center px-4 py-2 bg-saffron-100 text-saffron-800 rounded-full text-sm font-medium">
              👩‍🎨 {SITE_CONFIG.BRAND_VALUES.womenOwned}
            </span>
            <span class="inline-flex items-center px-4 py-2 bg-emerald-100 text-emerald-800 rounded-full text-sm font-medium font-hindi">
              🇮🇳 {SITE_CONFIG.BRAND_VALUES.madeInIndia}
            </span>
            <span class="inline-flex items-center px-4 py-2 bg-turmeric-100 text-turmeric-800 rounded-full text-sm font-medium font-hindi">
              💪 {SITE_CONFIG.BRAND_VALUES.atmanirbhar}
            </span>
          </div>
        </div>
        
        <!-- Enhanced CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-16">
          <a 
            href="/shop" 
            class="group inline-flex items-center px-8 py-4 bg-gradient-to-r from-saffron-600 to-saffron-700 hover:from-saffron-700 hover:to-saffron-800 text-white font-semibold rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 hover:scale-105"
          >
            <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            Shop Now
            <span class="ml-2 group-hover:translate-x-1 transition-transform">🛍️</span>
          </a>
          
          <a 
            href="/about" 
            class="group inline-flex items-center px-8 py-4 bg-white hover:bg-emerald-50 text-emerald-700 font-semibold rounded-2xl shadow-lg hover:shadow-xl border-2 border-emerald-200 hover:border-emerald-300 transition-all duration-300 transform hover:-translate-y-1"
          >
            <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Our Story
            <span class="ml-2 group-hover:translate-x-1 transition-transform">📖</span>
          </a>
        </div>
        
        <!-- Statistics highlighting women empowerment -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
          {Object.entries(WOMEN_EMPOWERMENT.stats).map(([, stat]) => (
            <div class="text-center bg-white/90 backdrop-blur-sm rounded-xl p-4 shadow-lg border border-saffron-100">
              <div class="text-2xl sm:text-3xl font-bold text-emerald-800 mb-1">{stat.split(' ')[0]}</div>
              <div class="text-sm text-neutral-700 font-medium">{stat.split(' ').slice(1).join(' ')}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Atmanirbhar Bharat & Women Empowerment Section -->
  <section class="py-20 bg-gradient-to-r from-emerald-50 via-white to-saffron-50   ">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-6xl mx-auto">
        <!-- Section Header -->
        <div class="text-center mb-16">
          <h2 class="text-4xl sm:text-5xl font-decorative font-bold mb-6">
            <span class="bg-gradient-to-r from-saffron-600 to-emerald-600 bg-clip-text text-transparent font-hindi">
              {ATMANIRBHAR_MESSAGING.title}
            </span>
          </h2>
          <p class="text-xl text-neutral-700  mb-8 max-w-3xl mx-auto">
            {ATMANIRBHAR_MESSAGING.subtitle}
          </p>
        </div>
        
        <!-- Two Column Layout -->
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Women Empowerment -->
          <div class="bg-white/70 backdrop-blur-sm rounded-3xl p-8 shadow-xl border border-saffron-100">
            <div class="text-center mb-6">
              <div class="w-16 h-16 bg-saffron-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-3xl">👩‍🎨</span>
              </div>
              <h3 class="text-2xl font-decorative font-bold text-saffron-700 mb-2">
                {WOMEN_EMPOWERMENT.tagline}
              </h3>
            </div>
            <ul class="space-y-3">
              {WOMEN_EMPOWERMENT.values.map((value) => (
                <li class="flex items-start">
                  <span class="text-saffron-500 text-lg mr-3">🌸</span>
                  <span class="text-neutral-700 ">{value}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <!-- Atmanirbhar Bharat -->
          <div class="bg-white/70 backdrop-blur-sm rounded-3xl p-8 shadow-xl border border-emerald-100">
            <div class="text-center mb-6">
              <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-3xl">🇮🇳</span>
              </div>
              <h3 class="text-2xl font-decorative font-bold text-emerald-700 mb-2 font-hindi">
                Made in India Movement
              </h3>
            </div>
            <ul class="space-y-3">
              {ATMANIRBHAR_MESSAGING.benefits.map((benefit) => (
                <li class="flex items-start">
                  <span class="text-emerald-600 text-lg mr-3">🏛️</span>
                  <span class="text-neutral-800  font-medium">{benefit}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
        
        <!-- Call to Action -->
        <div class="text-center mt-12">
          <p class="text-lg text-neutral-600 mb-6 font-hindi">
            हर खरीदारी से मजबूत बने भारत | Every Purchase Strengthens India
          </p>
          <a 
            href="/shop" 
            class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-emerald-600 to-saffron-600 text-white font-semibold rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1"
          >
            Support Indian Artisans
            <span class="ml-2">🙏</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Search Section -->
  <section class="py-12 bg-white ">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-md mx-auto">
        <h2 class="text-2xl font-serif font-semibold text-center text-neutral-900  mb-6">
          Find Your Perfect Craft
        </h2>
        <SearchBar className="w-full" />
      </div>
    </div>
  </section>

  <!-- Shop by Category Section -->
  <section class="py-20 bg-gradient-to-br from-neutral-50 via-saffron-25 to-emerald-25  relative overflow-hidden">
    <!-- Indian pattern background -->
    <div class="absolute inset-0 bg-rangoli opacity-5"></div>
    
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center mb-16">
        <h2 class="text-4xl sm:text-5xl font-decorative font-bold text-neutral-900  mb-6">
          <span class="bg-gradient-to-r from-saffron-700 to-emerald-700 bg-clip-text text-transparent">
            Shop by Category
          </span>
        </h2>
        <p class="text-xl text-neutral-700  max-w-3xl mx-auto mb-4 font-medium">
          Discover our carefully curated collection of handmade treasures, each category representing centuries of Indian artistry.
        </p>
        <p class="text-lg text-emerald-800 font-hindi font-semibold">
          भारतीय कलाकृतियों का खजाना | Treasury of Indian Arts
        </p>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {categories.map((category, index) => (
          <a 
            href={category.href}
            class="group relative bg-white/80 backdrop-blur-sm  rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-500 border-2 border-gradient-to-r from-saffron-200 to-emerald-200  text-center transform hover:-translate-y-4 hover:rotate-1"
            style={`animation-delay: ${index * 150}ms`}
          >
            <!-- Decorative corner elements -->
            <div class="absolute top-3 left-3 w-6 h-6 border-l-2 border-t-2 border-saffron-300 rounded-tl-lg"></div>
            <div class="absolute top-3 right-3 w-6 h-6 border-r-2 border-t-2 border-emerald-300 rounded-tr-lg"></div>
            <div class="absolute bottom-3 left-3 w-6 h-6 border-l-2 border-b-2 border-emerald-300 rounded-bl-lg"></div>
            <div class="absolute bottom-3 right-3 w-6 h-6 border-r-2 border-b-2 border-saffron-300 rounded-br-lg"></div>
            
            <div class="relative">
              <div class="text-6xl mb-6 group-hover:scale-125 transition-transform duration-300 filter drop-shadow-lg">
                {category.icon}
              </div>
              <h3 class="text-xl font-decorative font-bold text-neutral-900  mb-2 group-hover:text-saffron-700 transition-colors">
                {category.name}
              </h3>
              <p class="text-sm text-saffron-700 font-hindi mb-3 font-semibold">
                {category.hindi}
              </p>
              <p class="text-sm text-neutral-700  leading-relaxed font-medium">
                {category.description}
              </p>
              
              <!-- Hover effect arrow -->
              <div class="mt-4 opacity-0 group-hover:opacity-100 transition-opacity">
                <span class="inline-flex items-center text-emerald-600 font-medium">
                  Explore
                  <svg class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
      
      <div class="text-center mt-16">
        <a 
          href="/shop" 
          class="group inline-flex items-center px-10 py-4 bg-gradient-to-r from-saffron-600 to-emerald-600 hover:from-saffron-700 hover:to-emerald-700 text-white font-decorative font-semibold text-lg rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2"
        >
          <span class="mr-3">🎨</span>
          View All Collections
          <svg class="w-5 h-5 ml-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Products Section -->
  {featuredProducts.length > 0 && (
    <section class="py-16 bg-white ">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-serif font-bold text-neutral-900  mb-4">
            Featured Products
          </h2>
          <p class="text-lg text-neutral-600  max-w-2xl mx-auto">
            Handpicked selections from our artisans, showcasing the finest craftsmanship and artistic excellence.
          </p>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {featuredProducts.map((product) => (
            <ProductCard product={product} variant="featured" showDescription={true} />
          ))}
        </div>
        
        <div class="text-center mt-12">
          <a 
            href="/shop?filter=featured" 
            class="inline-flex items-center px-6 py-3 border border-primary-600 text-primary-600 hover:bg-primary-600 hover:text-white font-medium rounded-lg transition-all duration-200"
          >
            View All Featured Items
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- About Section -->
  <section class="py-16 bg-gradient-to-r from-accent-50 to-primary-50  ">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <!-- Text Content -->
          <div>
            <h2 class="text-3xl sm:text-4xl font-serif font-bold text-neutral-900  mb-6">
              About Our Artisans
            </h2>
            <p class="text-lg text-neutral-800  mb-6 leading-relaxed font-medium">
              Every piece in our collection tells a story of tradition, skill, and passion. Our artisans across India pour their heart and soul into creating unique, handmade treasures that celebrate our rich cultural heritage.
            </p>
            <p class="text-lg text-neutral-800  mb-8 leading-relaxed font-medium">
              From the bustling workshops of Delhi to the serene pottery villages of Gujarat, we work directly with craftspeople to bring you authentic, high-quality handmade products.
            </p>
            <a 
              href="/about" 
              class="inline-flex items-center px-6 py-3 bg-accent-600 hover:bg-accent-700 text-white font-medium rounded-lg transition-colors"
            >
              Learn More About Us
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
          
          <!-- Image Placeholder -->
          <div class="relative">
            <div class="aspect-square rounded-2xl overflow-hidden bg-neutral-200 ">
              <!-- Replace with actual artisan image -->
              <img 
                src="https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=600&h=600&fit=crop&auto=format&q=80" 
                alt="Artisan crafting pottery" 
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="absolute -bottom-6 -right-6 bg-white  rounded-xl p-4 shadow-lg border border-neutral-200 ">
              <p class="text-sm font-medium text-neutral-900 ">🇮🇳 Made in India</p>
              <p class="text-xs text-neutral-700  font-medium">With love & tradition</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter/Contact Section -->
  <section class="py-16 bg-primary-600">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl font-serif font-bold text-white mb-4">
          Stay Connected
        </h2>
        <p class="text-primary-100 mb-8 text-lg">
          Get updates on new arrivals, special offers, and stories from our artisan community.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a 
            href={`https://wa.me/${SITE_CONFIG.WHATSAPP_NUMBER_INTL.replace('+', '')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-6 py-3 bg-green-600 hover:bg-green-700 text-white font-medium rounded-lg transition-colors shadow-lg"
          >
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.570-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893A11.821 11.821 0 0020.465 3.488"/>
            </svg>
            Chat with Us
          </a>
          
          <a 
            href={`https://instagram.com/${SITE_CONFIG.INSTAGRAM.replace('@', '')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-6 py-3 bg-white/20 hover:bg-white/30 text-white font-medium rounded-lg transition-colors backdrop-blur-sm"
          >
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 6.62 5.367 11.987 11.988 11.987 6.62 0 11.987-5.367 11.987-11.987C24.014 5.367 18.637.001 12.017.001zm5.765 18.462c-.728.988-1.798 1.798-3.187 2.412-1.464.649-3.043.974-4.699.974-1.656 0-3.235-.325-4.699-.974-1.389-.614-2.459-1.424-3.187-2.412-.728-.988-1.296-2.13-1.687-3.398-.364-1.182-.546-2.396-.546-3.623s.182-2.441.546-3.623c.391-1.268.959-2.41 1.687-3.398.728-.988 1.798-1.798 3.187-2.412C8.782.675 10.361.35 12.017.35s3.235.325 4.699.974c1.389.614 2.459 1.424 3.187 2.412.728.988 1.296 2.13 1.687 3.398.364 1.182.546 2.396.546 3.623s-.182 2.441-.546 3.623c-.391 1.268-.959 2.41-1.687 3.398z"/>
              <path d="M12.017 5.351c-3.667 0-6.636 2.969-6.636 6.636s2.969 6.636 6.636 6.636 6.636-2.969 6.636-6.636-2.969-6.636-6.636-6.636zm0 10.942c-2.373 0-4.306-1.933-4.306-4.306s1.933-4.306 4.306-4.306 4.306 1.933 4.306 4.306-1.933 4.306-4.306 4.306z"/>
              <circle cx="18.651" cy="5.351" r="1.564"/>
            </svg>
            Follow Us
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
