---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductCard from '@/components/ProductCard.astro';
import SearchBar from '@/components/SearchBar.astro';
import { SITE_CONFIG } from '@/utils/constants';
import { generateSEO } from '@/utils/helpers';
import { getCollection } from 'astro:content';

// Load featured products from content collection
const allProducts = await getCollection('products');
const featuredProducts = allProducts
  .filter(product => product.data.featured || product.data.bestseller)
  .slice(0, 6)
  .map(product => ({
    ...product.data,
    slug: product.slug,
    content: product.body,
    url: `/products/${product.slug}`,
  }));

// If no featured products, show first 6 products
if (featuredProducts.length === 0) {
  featuredProducts.push(...allProducts.slice(0, 6).map(product => ({
    ...product.data,
    slug: product.slug,
    content: product.body,
    url: `/products/${product.slug}`,
  })));
}

// SEO data
const seo = generateSEO({
  title: `${SITE_CONFIG.STORE_NAME} - ${SITE_CONFIG.TAGLINE}`,
  description: SITE_CONFIG.DESCRIPTION,
  type: 'website',
});

// Categories for quick navigation
const categories = [
  {
    name: 'Festive Decor',
    href: '/category/festive-decor',
    icon: '🪔',
    description: 'Traditional diyas, rangoli, and festive items',
  },
  {
    name: 'Home Decor',
    href: '/category/home-decor',
    icon: '🏺',
    description: 'Beautiful handmade items for your home',
  },
  {
    name: 'Pottery & Ceramics',
    href: '/category/pottery-ceramics',
    icon: '🏺',
    description: 'Handcrafted pottery and ceramic pieces',
  },
  {
    name: 'Textiles & Fabrics',
    href: '/category/textiles-fabrics',
    icon: '🧵',
    description: 'Traditional fabrics and textile art',
  },
];
---

<BaseLayout seo={seo}>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-primary-50 via-white to-accent-50 dark:from-primary-900/10 dark:via-neutral-900 dark:to-accent-900/10">
    <div class="absolute inset-0 bg-texture opacity-30"></div>
    <div class="relative container mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
      <div class="max-w-4xl mx-auto text-center">
        <!-- Main Heading -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-serif font-bold text-neutral-900 dark:text-neutral-100 mb-6">
          Welcome to <span class="text-primary-600">{SITE_CONFIG.STORE_NAME}</span>
        </h1>
        
        <!-- Tagline -->
        <p class="text-xl sm:text-2xl text-neutral-600 dark:text-neutral-400 mb-8 max-w-2xl mx-auto">
          {SITE_CONFIG.TAGLINE}
        </p>
        
        <!-- Description -->
        <p class="text-lg text-neutral-700 dark:text-neutral-300 mb-12 max-w-3xl mx-auto leading-relaxed">
          {SITE_CONFIG.DESCRIPTION}
        </p>
        
        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a 
            href="/shop" 
            class="inline-flex items-center px-8 py-4 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all duration-200 transform hover:-translate-y-1"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            Shop Now
          </a>
          
          <a 
            href="/about" 
            class="inline-flex items-center px-8 py-4 border-2 border-primary-600 text-primary-600 hover:bg-primary-600 hover:text-white font-semibold rounded-xl transition-all duration-200"
          >
            Our Story
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Decorative Elements -->
    <div class="absolute top-20 left-10 w-20 h-20 bg-primary-200 rounded-full opacity-20 animate-bounce"></div>
    <div class="absolute bottom-20 right-10 w-16 h-16 bg-accent-200 rounded-full opacity-20 animate-bounce" style="animation-delay: 1s;"></div>
  </section>

  <!-- Quick Search Section -->
  <section class="py-12 bg-white dark:bg-neutral-900">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-md mx-auto">
        <h2 class="text-2xl font-serif font-semibold text-center text-neutral-900 dark:text-neutral-100 mb-6">
          Find Your Perfect Craft
        </h2>
        <SearchBar className="w-full" />
      </div>
    </div>
  </section>

  <!-- Shop by Category Section -->
  <section class="py-16 bg-neutral-50 dark:bg-neutral-800">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-serif font-bold text-neutral-900 dark:text-neutral-100 mb-4">
          Shop by Category
        </h2>
        <p class="text-lg text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto">
          Discover our carefully curated collection of handmade treasures, organized by category for easy browsing.
        </p>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {categories.map((category) => (
          <a 
            href={category.href}
            class="group bg-white dark:bg-neutral-900 rounded-2xl p-6 shadow-sm hover:shadow-xl transition-all duration-300 border border-neutral-200 dark:border-neutral-700 text-center transform hover:-translate-y-2"
          >
            <div class="text-4xl mb-4 group-hover:scale-110 transition-transform duration-200">
              {category.icon}
            </div>
            <h3 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100 mb-2 group-hover:text-primary-600 transition-colors">
              {category.name}
            </h3>
            <p class="text-sm text-neutral-600 dark:text-neutral-400">
              {category.description}
            </p>
          </a>
        ))}
      </div>
      
      <div class="text-center mt-12">
        <a 
          href="/shop" 
          class="inline-flex items-center px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-colors"
        >
          View All Products
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Products Section -->
  {featuredProducts.length > 0 && (
    <section class="py-16 bg-white dark:bg-neutral-900">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-serif font-bold text-neutral-900 dark:text-neutral-100 mb-4">
            Featured Products
          </h2>
          <p class="text-lg text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto">
            Handpicked selections from our artisans, showcasing the finest craftsmanship and artistic excellence.
          </p>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {featuredProducts.map((product) => (
            <ProductCard product={product} variant="featured" showDescription={true} />
          ))}
        </div>
        
        <div class="text-center mt-12">
          <a 
            href="/shop?filter=featured" 
            class="inline-flex items-center px-6 py-3 border border-primary-600 text-primary-600 hover:bg-primary-600 hover:text-white font-medium rounded-lg transition-all duration-200"
          >
            View All Featured Items
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- About Section -->
  <section class="py-16 bg-gradient-to-r from-accent-50 to-primary-50 dark:from-accent-900/10 dark:to-primary-900/10">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <!-- Text Content -->
          <div>
            <h2 class="text-3xl sm:text-4xl font-serif font-bold text-neutral-900 dark:text-neutral-100 mb-6">
              About Our Artisans
            </h2>
            <p class="text-lg text-neutral-700 dark:text-neutral-300 mb-6 leading-relaxed">
              Every piece in our collection tells a story of tradition, skill, and passion. Our artisans across India pour their heart and soul into creating unique, handmade treasures that celebrate our rich cultural heritage.
            </p>
            <p class="text-lg text-neutral-700 dark:text-neutral-300 mb-8 leading-relaxed">
              From the bustling workshops of Delhi to the serene pottery villages of Gujarat, we work directly with craftspeople to bring you authentic, high-quality handmade products.
            </p>
            <a 
              href="/about" 
              class="inline-flex items-center px-6 py-3 bg-accent-600 hover:bg-accent-700 text-white font-medium rounded-lg transition-colors"
            >
              Learn More About Us
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
          
          <!-- Image Placeholder -->
          <div class="relative">
            <div class="aspect-square rounded-2xl overflow-hidden bg-neutral-200 dark:bg-neutral-700">
              <!-- Replace with actual artisan image -->
              <img 
                src="https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=600&h=600&fit=crop&auto=format&q=80" 
                alt="Artisan crafting pottery" 
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="absolute -bottom-6 -right-6 bg-white dark:bg-neutral-800 rounded-xl p-4 shadow-lg border border-neutral-200 dark:border-neutral-700">
              <p class="text-sm font-medium text-neutral-900 dark:text-neutral-100">🇮🇳 Made in India</p>
              <p class="text-xs text-neutral-600 dark:text-neutral-400">With love & tradition</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter/Contact Section -->
  <section class="py-16 bg-primary-600">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl font-serif font-bold text-white mb-4">
          Stay Connected
        </h2>
        <p class="text-primary-100 mb-8 text-lg">
          Get updates on new arrivals, special offers, and stories from our artisan community.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a 
            href={`https://wa.me/${SITE_CONFIG.WHATSAPP_NUMBER_INTL.replace('+', '')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-6 py-3 bg-green-600 hover:bg-green-700 text-white font-medium rounded-lg transition-colors shadow-lg"
          >
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.570-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893A11.821 11.821 0 0020.465 3.488"/>
            </svg>
            Chat with Us
          </a>
          
          <a 
            href={`https://instagram.com/${SITE_CONFIG.INSTAGRAM.replace('@', '')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-6 py-3 bg-white/20 hover:bg-white/30 text-white font-medium rounded-lg transition-colors backdrop-blur-sm"
          >
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 6.62 5.367 11.987 11.988 11.987 6.62 0 11.987-5.367 11.987-11.987C24.014 5.367 18.637.001 12.017.001zm5.765 18.462c-.728.988-1.798 1.798-3.187 2.412-1.464.649-3.043.974-4.699.974-1.656 0-3.235-.325-4.699-.974-1.389-.614-2.459-1.424-3.187-2.412-.728-.988-1.296-2.13-1.687-3.398-.364-1.182-.546-2.396-.546-3.623s.182-2.441.546-3.623c.391-1.268.959-2.41 1.687-3.398.728-.988 1.798-1.798 3.187-2.412C8.782.675 10.361.35 12.017.35s3.235.325 4.699.974c1.389.614 2.459 1.424 3.187 2.412.728.988 1.296 2.13 1.687 3.398.364 1.182.546 2.396.546 3.623s-.182 2.441-.546 3.623c-.391 1.268-.959 2.41-1.687 3.398z"/>
              <path d="M12.017 5.351c-3.667 0-6.636 2.969-6.636 6.636s2.969 6.636 6.636 6.636 6.636-2.969 6.636-6.636-2.969-6.636-6.636-6.636zm0 10.942c-2.373 0-4.306-1.933-4.306-4.306s1.933-4.306 4.306-4.306 4.306 1.933 4.306 4.306-1.933 4.306-4.306 4.306z"/>
              <circle cx="18.651" cy="5.351" r="1.564"/>
            </svg>
            Follow Us
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>