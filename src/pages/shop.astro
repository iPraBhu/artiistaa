---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductCard from '@/components/ProductCard.astro';
import SearchBar from '@/components/SearchBar.astro';
import Filters from '@/components/Filters.astro';
import { SITE_CONFIG } from '@/utils/constants';
import { generateSEO, getUniqueCategories, getUniqueTags, slugify, toAbsoluteUrl } from '@/utils/helpers';
import { getCollection } from 'astro:content';

// Load all products from content collection
const allProducts = await getCollection('products');
const products = allProducts.map(product => ({
  ...product.data,
  slug: product.id,
  content: product.body,
  url: `/products/${product.id}`,
}));

// Get unique categories and tags for filters
const categories = getUniqueCategories(products);
const tags = getUniqueTags(products);

// SEO data
const seo = generateSEO({
  title: `Shop All Products`,
  description: `Browse our complete collection of handmade art and craft items from skilled artisans across India.`,
});

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${SITE_CONFIG.STORE_NAME} Products`,
  numberOfItems: products.length,
  itemListElement: products.map((product, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: toAbsoluteUrl(product.url),
    name: product.title,
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: toAbsoluteUrl('/'),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Shop',
      item: toAbsoluteUrl('/shop'),
    },
  ],
};
---

<BaseLayout seo={seo}>
  <!-- Page Header -->
  <section class="bg-neutral-50  py-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-3xl sm:text-4xl font-serif font-bold text-neutral-900  mb-4">
          Our Complete Collection
        </h1>
        <p class="text-lg text-neutral-600  mb-8">
          Discover beautiful handmade treasures crafted with love by skilled artisans across India.
        </p>
        
        <!-- Main Search -->
        <div class="max-w-md mx-auto">
          <SearchBar />
        </div>
      </div>
    </div>
  </section>

  <!-- Main Shop Section -->
  <section class="py-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Filters Sidebar -->
        <aside class="lg:w-80 flex-shrink-0">
          <div class="sticky top-24">
            <Filters categories={categories} tags={tags} />
          </div>
        </aside>

        <!-- Products Grid -->
        <main class="flex-1">
          <!-- Results Header -->
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
            <div>
              <h2 class="text-2xl font-semibold text-neutral-900 ">
                All Products
              </h2>
              <p id="results-count" class="text-neutral-600  mt-1">
                {products.length === 0 ? 'No products yet - coming soon!' : `Showing ${products.length} products`}
              </p>
            </div>
            
            <!-- View Toggle (Desktop) -->
            <div class="hidden sm:flex items-center space-x-2 bg-white  rounded-lg border border-neutral-200  p-1">
              <button 
                id="grid-view" 
                class="p-2 rounded-md bg-primary-100 text-primary-700  "
                aria-label="Grid view"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM11 13a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                </svg>
              </button>
              <button 
                id="list-view" 
                class="p-2 rounded-md text-neutral-500 hover:text-primary-700 hover:bg-primary-50  transition-colors"
                aria-label="List view"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd" />
                </svg>
              </button>
            </div>
          </div>

          <!-- Products Container -->
          <div id="products-container" class="products-grid">
            {products.length === 0 ? (
              <div class="col-span-full py-16 text-center">
                <div class="max-w-md mx-auto">
                  <svg class="w-24 h-24 mx-auto text-neutral-300  mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M8 4l8 4" />
                  </svg>
                  <h3 class="text-xl font-semibold text-neutral-900  mb-2">
                    Products Coming Soon
                  </h3>
                  <p class="text-neutral-600  mb-6">
                    We're currently adding our beautiful collection of handmade crafts. Check back soon!
                  </p>
                  <a 
                    href={`https://wa.me/${SITE_CONFIG.WHATSAPP_NUMBER_INTL.replace('+', '')}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center px-6 py-3 bg-green-600 hover:bg-green-700 text-white font-medium rounded-lg transition-colors"
                  >
                    <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.570-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893A11.821 11.821 0 0020.465 3.488"/>
                    </svg>
                    Contact Us for Custom Orders
                  </a>
                </div>
              </div>
            ) : (
              products.map((product) => (
                <div
                  class="shop-product-item"
                  data-categories={product.categories.map((category: string) => slugify(category)).join('|')}
                  data-tags={product.tags.map((tag: string) => slugify(tag)).join('|')}
                  data-price={product.price}
                  data-in-stock={product.in_stock !== false ? 'true' : 'false'}
                  data-featured={product.featured ? 'true' : 'false'}
                  data-bestseller={product.bestseller ? 'true' : 'false'}
                  data-new={product.new ? 'true' : 'false'}
                  data-limited={product.limited ? 'true' : 'false'}
                >
                  <ProductCard product={product} />
                </div>
              ))
            )}
          </div>

          <!-- Load More Button (for future pagination) -->
          {products.length > 12 && (
            <div class="text-center mt-12">
              <button 
                id="load-more"
                class="px-8 py-3 border border-neutral-300  text-neutral-700  hover:bg-neutral-50  font-medium rounded-lg transition-colors"
              >
                Load More Products
              </button>
            </div>
          )}
        </main>
      </div>
    </div>
  </section>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>

<style>
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }
  
  .products-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  
  @media (max-width: 640px) {
    .products-grid {
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 1.5rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    interface FilterState {
      categories: string[];
      tags: string[];
      special: string[];
      priceSort: '' | 'asc' | 'desc';
      priceMin: string;
      priceMax: string;
      inStockOnly: boolean;
    }

    const defaultFilters: FilterState = {
      categories: [],
      tags: [],
      special: [],
      priceSort: '',
      priceMin: '',
      priceMax: '',
      inStockOnly: false,
    };

    const gridViewBtn = document.getElementById('grid-view');
    const listViewBtn = document.getElementById('list-view');
    const productsContainer = document.getElementById('products-container');
    const resultsCount = document.getElementById('results-count');
    const productItems = Array.from(document.querySelectorAll('.shop-product-item')) as HTMLDivElement[];
    let activeFilters: FilterState = { ...defaultFilters };
    
    function setView(view: 'grid' | 'list') {
      if (!gridViewBtn || !listViewBtn || !productsContainer) return;

      const isList = view === 'list';
      productsContainer.className = isList ? 'products-list' : 'products-grid';

      const selectedButton = isList ? listViewBtn : gridViewBtn;
      const unselectedButton = isList ? gridViewBtn : listViewBtn;

      selectedButton.classList.add('bg-primary-100', 'text-primary-700');
      selectedButton.classList.remove('text-neutral-500', 'hover:text-primary-700', 'hover:bg-primary-50');

      unselectedButton.classList.remove('bg-primary-100', 'text-primary-700');
      unselectedButton.classList.add('text-neutral-500', 'hover:text-primary-700', 'hover:bg-primary-50');

      const cards = productsContainer.querySelectorAll('[data-product-card]');
      cards.forEach((card) => {
        card.setAttribute('data-variant', view);
      });
    }

    function includesAny(haystack: string, needles: string[]): boolean {
      if (needles.length === 0) return true;
      const values = haystack.split('|').filter(Boolean);
      return needles.some((needle) => values.includes(needle));
    }

    function matchesSpecialFilters(item: HTMLDivElement, filters: FilterState): boolean {
      if (filters.special.length === 0) return true;
      return filters.special.every((special) => item.dataset[special] === 'true');
    }

    function matchesPrice(item: HTMLDivElement, filters: FilterState): boolean {
      const price = Number(item.dataset.price || 0);
      const min = Number(filters.priceMin || 0);
      const max = Number(filters.priceMax || Number.POSITIVE_INFINITY);
      if (!Number.isFinite(price)) return false;
      return price >= min && price <= max;
    }

    function updateResultLabel(visibleCount: number) {
      if (!resultsCount) return;
      if (productItems.length === 0) {
        resultsCount.textContent = 'No products yet - coming soon!';
        return;
      }
      resultsCount.textContent = `Showing ${visibleCount} of ${productItems.length} products`;
    }

    function applyFilters(filters: FilterState) {
      const normalizedCategories = filters.categories.map((category) => category.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, ''));
      const normalizedTags = filters.tags.map((tag) => tag.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, ''));

      const visibleItems: HTMLDivElement[] = [];

      productItems.forEach((item) => {
        const matchesCategory = includesAny(item.dataset.categories || '', normalizedCategories);
        const matchesTag = includesAny(item.dataset.tags || '', normalizedTags);
        const matchesStock = !filters.inStockOnly || item.dataset.inStock === 'true';
        const matchesSpecial = matchesSpecialFilters(item, filters);
        const matchesPriceRange = matchesPrice(item, filters);
        const isVisible = matchesCategory && matchesTag && matchesStock && matchesSpecial && matchesPriceRange;

        item.classList.toggle('hidden', !isVisible);
        if (isVisible) {
          visibleItems.push(item);
        }
      });

      if (filters.priceSort) {
        const multiplier = filters.priceSort === 'asc' ? 1 : -1;
        visibleItems
          .sort((a, b) => {
            const aPrice = Number(a.dataset.price || 0);
            const bPrice = Number(b.dataset.price || 0);
            return (aPrice - bPrice) * multiplier;
          })
          .forEach((item) => {
            productsContainer?.appendChild(item);
          });
      }

      updateResultLabel(visibleItems.length);
    }

    // View toggle functionality
    if (gridViewBtn && listViewBtn) {
      gridViewBtn.addEventListener('click', () => setView('grid'));
      listViewBtn.addEventListener('click', () => setView('list'));
    }
    
    // Listen for filter changes
    document.addEventListener('filtersChanged', (e: Event) => {
      const customEvent = e as CustomEvent<FilterState>;
      if (!customEvent.detail) return;
      activeFilters = { ...defaultFilters, ...customEvent.detail };
      applyFilters(activeFilters);
    });

    // Support links like /shop?filter=featured
    const params = new URLSearchParams(window.location.search);
    const specialFilter = params.get('filter');
    if (specialFilter) {
      const selector = `input[name="special"][value="${specialFilter}"]`;
      const input = document.querySelector(selector) as HTMLInputElement | null;
      if (input) {
        input.checked = true;
        input.dispatchEvent(new Event('change', { bubbles: true }));
      }
    }

    setView('grid');
    applyFilters(activeFilters);
  });
</script>
