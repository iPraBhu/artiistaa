---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { generateSEO } from '@/utils/helpers';

const seo = generateSEO({
  title: 'Privacy Policy',
  description: 'Read how Artiistaa handles customer information and privacy.',
  type: 'website',
});
---

<BaseLayout seo={seo}>
  <section class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="max-w-3xl mx-auto prose prose-neutral ">
      <h1>Privacy Policy</h1>
      <p>We collect only the information required to process orders and customer support requests.</p>
      <h2>Information We Collect</h2>
      <p>Contact details you provide directly, such as name, phone number, and email address.</p>
      <h2>How We Use Data</h2>
      <p>Order communication, delivery updates, and service improvement. We do not sell personal data.</p>
      <h2>Contact</h2>
      <p>If you have privacy questions, contact us via the details on the contact page.</p>
    </div>
  </section>
</BaseLayout>
