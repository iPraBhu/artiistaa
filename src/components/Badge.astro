---
interface Props {
  badges: string[];
  size?: 'sm' | 'md' | 'lg';
  className?: string;
}

const { badges, size = 'md', className = '' } = Astro.props;

const sizeClasses = {
  sm: 'px-2 py-1 text-xs',
  md: 'px-3 py-1 text-sm',
  lg: 'px-4 py-2 text-base'
};

const badgeStyles = {
  'NEW': 'bg-green-100 text-green-800 border-green-200   ',
  'FEATURED': 'bg-primary-100 text-primary-800 border-primary-200   ',
  'BESTSELLER': 'bg-amber-100 text-amber-800 border-amber-200   ',
  'LIMITED': 'bg-red-100 text-red-800 border-red-200   ',
  'OUT OF STOCK': 'bg-neutral-100 text-neutral-600 border-neutral-300   '
};
---

{badges.length > 0 && (
  <div class={`flex flex-wrap gap-2 ${className}`}>
    {badges.map((badge) => (
      <span 
        class={`inline-flex items-center font-medium rounded-full border ${sizeClasses[size]} ${badgeStyles[badge as keyof typeof badgeStyles] || badgeStyles['NEW']}`}
      >
        {badge}
      </span>
    ))}
  </div>
)}