---
interface Props {
  className?: string;
  placeholder?: string;
}

const { className = '', placeholder = 'Search products...' } = Astro.props;
---

<div class={`search-container ${className}`}>
  <div class="relative">
    <input 
      type="search" 
      id="search-input"
      placeholder={placeholder}
      class="w-full px-4 py-3 pl-12 pr-4 text-base border border-neutral-300 dark:border-neutral-600 rounded-xl bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent shadow-sm"
      autocomplete="off"
      spellcheck="false"
    />
    
    <!-- Search Icon -->
    <svg class="absolute left-4 top-1/2 transform -translate-y-1/2 w-5 h-5 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m21 21-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    
    <!-- Clear Button -->
    <button 
      id="clear-search"
      class="absolute right-3 top-1/2 transform -translate-y-1/2 p-1 rounded-full hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors hidden"
      aria-label="Clear search"
    >
      <svg class="w-4 h-4 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
  
  <!-- Search Results -->
  <div id="search-results" class="absolute z-50 w-full mt-2 bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-xl shadow-lg hidden max-h-96 overflow-y-auto">
    <div id="search-results-content" class="p-2">
      <!-- Results will be populated by JavaScript -->
    </div>
    
    <!-- No Results -->
    <div id="no-results" class="p-4 text-center text-neutral-500 dark:text-neutral-400 hidden">
      <svg class="w-12 h-12 mx-auto mb-2 text-neutral-300 dark:text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <p class="text-sm">No products found</p>
      <p class="text-xs mt-1">Try searching with different keywords</p>
    </div>
    
    <!-- Loading -->
    <div id="search-loading" class="p-4 text-center text-neutral-500 dark:text-neutral-400 hidden">
      <div class="inline-block animate-spin rounded-full h-6 w-6 border-b-2 border-primary-600"></div>
      <p class="text-sm mt-2">Searching...</p>
    </div>
  </div>
</div>

<script>
  import Fuse from 'fuse.js';
  
  document.addEventListener('DOMContentLoaded', async () => {
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const clearButton = document.getElementById('clear-search');
    const searchResults = document.getElementById('search-results');
    const searchResultsContent = document.getElementById('search-results-content');
    const noResults = document.getElementById('no-results');
    const searchLoading = document.getElementById('search-loading');
    
    let fuse: Fuse<any> | null = null;
    let searchData: any[] = [];
    
    // Load search data
    try {
      const response = await fetch('/search.json');
      searchData = await response.json();
      
      // Initialize Fuse.js
      fuse = new Fuse(searchData, {
        keys: ['title', 'short', 'tags', 'categories'],
        threshold: 0.3,
        includeMatches: true,
        minMatchCharLength: 2,
      });
    } catch (error) {
      console.error('Failed to load search data:', error);
    }
    
    // Debounce function
    function debounce<T extends (...args: any[]) => any>(func: T, wait: number) {
      let timeout: ReturnType<typeof setTimeout>;
      return (...args: Parameters<T>) => {
        clearTimeout(timeout);
        timeout = setTimeout(() => func.apply(null, args), wait);
      };
    }
    
    // Search function
    function performSearch(query: string) {
      if (!fuse || !query.trim()) {
        hideResults();
        return;
      }
      
      showLoading();
      
      // Simulate slight delay for better UX
      setTimeout(() => {
        const results = fuse.search(query);
        displayResults(results.slice(0, 10)); // Limit to 10 results
      }, 100);
    }
    
    // Display search results
    function displayResults(results: any[]) {
      if (!searchResultsContent || !searchResults || !noResults) return;
      
      hideLoading();
      
      if (results.length === 0) {
        searchResultsContent.innerHTML = '';
        noResults.classList.remove('hidden');
        searchResults.classList.remove('hidden');
        return;
      }
      
      noResults.classList.add('hidden');
      
      const resultsHTML = results.map(result => {
        const item = result.item;
        const price = item.currency === 'INR' ? `₹${item.price.toLocaleString('en-IN')}` : `${item.currency} ${item.price}`;
        
        return `
          <a href="${item.url}" class="block p-3 rounded-lg hover:bg-neutral-50 dark:hover:bg-neutral-700 transition-colors">
            <div class="flex items-center space-x-3">
              <div class="flex-shrink-0 w-12 h-12 rounded-lg overflow-hidden bg-neutral-100 dark:bg-neutral-700">
                <img src="${item.image}" alt="${item.title}" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-neutral-900 dark:text-neutral-100 truncate">${item.title}</p>
                <p class="text-xs text-neutral-500 dark:text-neutral-400 truncate">${item.short}</p>
                <div class="flex items-center justify-between mt-1">
                  <span class="text-sm font-semibold text-primary-600">${price}</span>
                  ${item.badges.length > 0 ? `<span class="text-xs px-2 py-1 bg-primary-100 text-primary-800 rounded-full">${item.badges[0]}</span>` : ''}
                </div>
              </div>
            </div>
          </a>
        `;
      }).join('');
      
      searchResultsContent.innerHTML = resultsHTML;
      searchResults.classList.remove('hidden');
    }
    
    // Show/hide helper functions
    function showLoading() {
      if (searchLoading && searchResults) {
        searchResults.classList.remove('hidden');
        searchLoading.classList.remove('hidden');
        if (searchResultsContent) searchResultsContent.innerHTML = '';
        if (noResults) noResults.classList.add('hidden');
      }
    }
    
    function hideLoading() {
      if (searchLoading) {
        searchLoading.classList.add('hidden');
      }
    }
    
    function hideResults() {
      if (searchResults) {
        searchResults.classList.add('hidden');
      }
      hideLoading();
    }
    
    // Event listeners
    const debouncedSearch = debounce(performSearch, 300);
    
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        const query = (e.target as HTMLInputElement).value;
        
        if (clearButton) {
          clearButton.classList.toggle('hidden', !query);
        }
        
        if (query.length >= 2) {
          debouncedSearch(query);
        } else {
          hideResults();
        }
      });
      
      // Handle focus/blur
      searchInput.addEventListener('focus', () => {
        if (searchInput.value.length >= 2) {
          debouncedSearch(searchInput.value);
        }
      });
      
      searchInput.addEventListener('blur', (e) => {
        // Delay hiding to allow clicking on results
        setTimeout(() => {
          if (!document.activeElement?.closest('#search-results')) {
            hideResults();
          }
        }, 150);
      });
    }
    
    // Clear button
    if (clearButton && searchInput) {
      clearButton.addEventListener('click', () => {
        searchInput.value = '';
        clearButton.classList.add('hidden');
        hideResults();
        searchInput.focus();
      });
    }
    
    // Close results when clicking outside
    document.addEventListener('click', (e) => {
      if (!(e.target as Element)?.closest('.search-container')) {
        hideResults();
      }
    });
    
    // Keyboard navigation
    if (searchInput) {
      searchInput.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          hideResults();
          searchInput.blur();
        }
      });
    }
  });
</script>

<style>
  .search-container {
    position: relative;
  }
  
  #search-results {
    animation: fadeInUp 0.2s ease-out;
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* Custom scrollbar for results */
  #search-results::-webkit-scrollbar {
    width: 6px;
  }
  
  #search-results::-webkit-scrollbar-track {
    background: transparent;
  }
  
  #search-results::-webkit-scrollbar-thumb {
    background: rgb(156 163 175 / 0.5);
    border-radius: 3px;
  }
  
  #search-results::-webkit-scrollbar-thumb:hover {
    background: rgb(107 114 128 / 0.7);
  }
</style>