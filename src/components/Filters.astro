---
interface Props {
  categories: string[];
  tags: string[];
  className?: string;
}

const { categories, tags, className = '' } = Astro.props;
---

<div class={`filters-container ${className}`}>
  <div class="bg-white dark:bg-neutral-800 rounded-xl border border-neutral-200 dark:border-neutral-700 p-6 shadow-sm">
    <!-- Filter Header -->
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100">
        Filters
      </h3>
      <button 
        id="clear-filters"
        class="text-sm text-primary-600 hover:text-primary-700 font-medium hidden"
      >
        Clear All
      </button>
    </div>

    <!-- Active Filters -->
    <div id="active-filters" class="mb-4 hidden">
      <div class="flex flex-wrap gap-2">
        <!-- Active filter tags will be inserted here -->
      </div>
    </div>

    <!-- Sort Options -->
    <div class="mb-6">
      <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">
        Sort by Price
      </label>
      <select 
        id="price-sort"
        class="w-full px-3 py-2 border border-neutral-300 dark:border-neutral-600 rounded-lg bg-white dark:bg-neutral-700 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-primary-500"
      >
        <option value="">Default</option>
        <option value="asc">Price: Low to High</option>
        <option value="desc">Price: High to Low</option>
      </select>
    </div>

    <!-- Price Range -->
    <div class="mb-6">
      <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">
        Price Range (₹)
      </label>
      <div class="grid grid-cols-2 gap-2">
        <input 
          type="number"
          id="price-min"
          placeholder="Min"
          min="0"
          class="px-3 py-2 border border-neutral-300 dark:border-neutral-600 rounded-lg bg-white dark:bg-neutral-700 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-primary-500"
        />
        <input 
          type="number"
          id="price-max"
          placeholder="Max"
          min="0"
          class="px-3 py-2 border border-neutral-300 dark:border-neutral-600 rounded-lg bg-white dark:bg-neutral-700 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-primary-500"
        />
      </div>
    </div>

    <!-- Categories Filter -->
    {categories.length > 0 && (
      <div class="mb-6">
        <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-3">
          Categories
        </label>
        <div class="space-y-2 max-h-40 overflow-y-auto">
          {categories.map((category) => (
            <label class="flex items-center">
              <input 
                type="checkbox" 
                name="category" 
                value={category}
                class="rounded border-neutral-300 text-primary-600 focus:ring-primary-500 focus:ring-offset-0"
              />
              <span class="ml-2 text-sm text-neutral-700 dark:text-neutral-300">
                {category}
              </span>
            </label>
          ))}
        </div>
      </div>
    )}

    <!-- Tags Filter -->
    {tags.length > 0 && (
      <div class="mb-6">
        <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-3">
          Tags
        </label>
        <div class="flex flex-wrap gap-2 max-h-32 overflow-y-auto">
          {tags.map((tag) => (
            <label class="inline-flex items-center">
              <input 
                type="checkbox" 
                name="tag" 
                value={tag}
                class="sr-only peer"
              />
              <span class="px-3 py-1 text-sm border border-neutral-300 dark:border-neutral-600 rounded-full cursor-pointer transition-colors peer-checked:bg-primary-100 peer-checked:border-primary-500 peer-checked:text-primary-700 hover:bg-neutral-50 dark:hover:bg-neutral-700 text-neutral-600 dark:text-neutral-400">
                {tag}
              </span>
            </label>
          ))}
        </div>
      </div>
    )}

    <!-- Stock Filter -->
    <div class="mb-6">
      <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-3">
        Availability
      </label>
      <label class="flex items-center">
        <input 
          type="checkbox" 
          id="in-stock-only"
          class="rounded border-neutral-300 text-primary-600 focus:ring-primary-500 focus:ring-offset-0"
        />
        <span class="ml-2 text-sm text-neutral-700 dark:text-neutral-300">
          In stock only
        </span>
      </label>
    </div>

    <!-- Special Items Filter -->
    <div>
      <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-3">
        Special Items
      </label>
      <div class="space-y-2">
        <label class="flex items-center">
          <input 
            type="checkbox" 
            name="special" 
            value="featured"
            class="rounded border-neutral-300 text-primary-600 focus:ring-primary-500 focus:ring-offset-0"
          />
          <span class="ml-2 text-sm text-neutral-700 dark:text-neutral-300">
            Featured Items
          </span>
        </label>
        <label class="flex items-center">
          <input 
            type="checkbox" 
            name="special" 
            value="bestseller"
            class="rounded border-neutral-300 text-primary-600 focus:ring-primary-500 focus:ring-offset-0"
          />
          <span class="ml-2 text-sm text-neutral-700 dark:text-neutral-300">
            Best Sellers
          </span>
        </label>
        <label class="flex items-center">
          <input 
            type="checkbox" 
            name="special" 
            value="new"
            class="rounded border-neutral-300 text-primary-600 focus:ring-primary-500 focus:ring-offset-0"
          />
          <span class="ml-2 text-sm text-neutral-700 dark:text-neutral-300">
            New Arrivals
          </span>
        </label>
        <label class="flex items-center">
          <input 
            type="checkbox" 
            name="special" 
            value="limited"
            class="rounded border-neutral-300 text-primary-600 focus:ring-primary-500 focus:ring-offset-0"
          />
          <span class="ml-2 text-sm text-neutral-700 dark:text-neutral-300">
            Limited Edition
          </span>
        </label>
      </div>
    </div>
  </div>

  <!-- Results Info -->
  <div id="results-info" class="mt-4 text-sm text-neutral-600 dark:text-neutral-400">
    <!-- Results count will be shown here -->
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const clearFiltersBtn = document.getElementById('clear-filters');
    const activeFiltersContainer = document.getElementById('active-filters');
    const resultsInfo = document.getElementById('results-info');
    const priceSort = document.getElementById('price-sort') as HTMLSelectElement;
    const priceMin = document.getElementById('price-min') as HTMLInputElement;
    const priceMax = document.getElementById('price-max') as HTMLInputElement;
    const inStockOnly = document.getElementById('in-stock-only') as HTMLInputElement;
    
    // Get all filter inputs
    const categoryFilters = document.querySelectorAll('input[name="category"]') as NodeListOf<HTMLInputElement>;
    const tagFilters = document.querySelectorAll('input[name="tag"]') as NodeListOf<HTMLInputElement>;
    const specialFilters = document.querySelectorAll('input[name="special"]') as NodeListOf<HTMLInputElement>;
    
    // Filter state
    let activeFilters = {
      categories: [] as string[],
      tags: [] as string[],
      special: [] as string[],
      priceSort: '',
      priceMin: '',
      priceMax: '',
      inStockOnly: false
    };
    
    // Debounce function for price inputs
    function debounce<T extends (...args: any[]) => any>(func: T, wait: number) {
      let timeout: ReturnType<typeof setTimeout>;
      return (...args: Parameters<T>) => {
        clearTimeout(timeout);
        timeout = setTimeout(() => func.apply(null, args), wait);
      };
    }
    
    // Update active filters display
    function updateActiveFilters() {
      if (!activeFiltersContainer) return;
      
      const filterTags: string[] = [];
      
      // Add category filters
      activeFilters.categories.forEach(category => {
        filterTags.push(`<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-primary-100 text-primary-800 dark:bg-primary-900/20 dark:text-primary-400">
          Category: ${category}
          <button type="button" class="ml-1 hover:text-primary-600" data-remove-filter="category:${category}">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </button>
        </span>`);
      });
      
      // Add tag filters
      activeFilters.tags.forEach(tag => {
        filterTags.push(`<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-accent-100 text-accent-800 dark:bg-accent-900/20 dark:text-accent-400">
          Tag: ${tag}
          <button type="button" class="ml-1 hover:text-accent-600" data-remove-filter="tag:${tag}">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </button>
        </span>`);
      });
      
      // Add special filters
      activeFilters.special.forEach(special => {
        filterTags.push(`<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-neutral-100 text-neutral-800 dark:bg-neutral-800 dark:text-neutral-300">
          ${special.charAt(0).toUpperCase() + special.slice(1)}
          <button type="button" class="ml-1 hover:text-neutral-600" data-remove-filter="special:${special}">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </button>
        </span>`);
      });
      
      // Add price range if set
      if (activeFilters.priceMin || activeFilters.priceMax) {
        const min = activeFilters.priceMin || '0';
        const max = activeFilters.priceMax || '∞';
        filterTags.push(`<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/20 dark:text-blue-400">
          ₹${min} - ₹${max}
          <button type="button" class="ml-1 hover:text-blue-600" data-remove-filter="price">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </button>
        </span>`);
      }
      
      // Add in-stock filter
      if (activeFilters.inStockOnly) {
        filterTags.push(`<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/20 dark:text-green-400">
          In Stock Only
          <button type="button" class="ml-1 hover:text-green-600" data-remove-filter="inStockOnly">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </button>
        </span>`);
      }
      
      if (filterTags.length > 0) {
        activeFiltersContainer.innerHTML = filterTags.join('');
        activeFiltersContainer.classList.remove('hidden');
        clearFiltersBtn?.classList.remove('hidden');
      } else {
        activeFiltersContainer.classList.add('hidden');
        clearFiltersBtn?.classList.add('hidden');
      }
      
      // Add click listeners to remove buttons
      activeFiltersContainer.querySelectorAll('[data-remove-filter]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const filterToRemove = (e.target as HTMLElement).closest('[data-remove-filter]')?.getAttribute('data-remove-filter');
          if (filterToRemove) {
            removeFilter(filterToRemove);
          }
        });
      });
    }
    
    // Remove specific filter
    function removeFilter(filter: string) {
      const [type, value] = filter.split(':');
      
      switch (type) {
        case 'category':
          activeFilters.categories = activeFilters.categories.filter(c => c !== value);
          const categoryInput = document.querySelector(`input[name="category"][value="${value}"]`) as HTMLInputElement;
          if (categoryInput) categoryInput.checked = false;
          break;
        case 'tag':
          activeFilters.tags = activeFilters.tags.filter(t => t !== value);
          const tagInput = document.querySelector(`input[name="tag"][value="${value}"]`) as HTMLInputElement;
          if (tagInput) tagInput.checked = false;
          break;
        case 'special':
          activeFilters.special = activeFilters.special.filter(s => s !== value);
          const specialInput = document.querySelector(`input[name="special"][value="${value}"]`) as HTMLInputElement;
          if (specialInput) specialInput.checked = false;
          break;
        case 'price':
          activeFilters.priceMin = '';
          activeFilters.priceMax = '';
          if (priceMin) priceMin.value = '';
          if (priceMax) priceMax.value = '';
          break;
        case 'inStockOnly':
          activeFilters.inStockOnly = false;
          if (inStockOnly) inStockOnly.checked = false;
          break;
      }
      
      updateActiveFilters();
      applyFilters();
    }
    
    // Apply filters to products
    function applyFilters() {
      // Dispatch custom event with current filters
      const filterEvent = new CustomEvent('filtersChanged', {
        detail: activeFilters
      });
      document.dispatchEvent(filterEvent);
    }
    
    // Event listeners
    categoryFilters.forEach(input => {
      input.addEventListener('change', (e) => {
        const value = (e.target as HTMLInputElement).value;
        const checked = (e.target as HTMLInputElement).checked;
        
        if (checked) {
          activeFilters.categories.push(value);
        } else {
          activeFilters.categories = activeFilters.categories.filter(c => c !== value);
        }
        
        updateActiveFilters();
        applyFilters();
      });
    });
    
    tagFilters.forEach(input => {
      input.addEventListener('change', (e) => {
        const value = (e.target as HTMLInputElement).value;
        const checked = (e.target as HTMLInputElement).checked;
        
        if (checked) {
          activeFilters.tags.push(value);
        } else {
          activeFilters.tags = activeFilters.tags.filter(t => t !== value);
        }
        
        updateActiveFilters();
        applyFilters();
      });
    });
    
    specialFilters.forEach(input => {
      input.addEventListener('change', (e) => {
        const value = (e.target as HTMLInputElement).value;
        const checked = (e.target as HTMLInputElement).checked;
        
        if (checked) {
          activeFilters.special.push(value);
        } else {
          activeFilters.special = activeFilters.special.filter(s => s !== value);
        }
        
        updateActiveFilters();
        applyFilters();
      });
    });
    
    // Price sort
    if (priceSort) {
      priceSort.addEventListener('change', (e) => {
        activeFilters.priceSort = (e.target as HTMLSelectElement).value;
        applyFilters();
      });
    }
    
    // Price range with debouncing
    const debouncedPriceFilter = debounce(() => {
      activeFilters.priceMin = priceMin?.value || '';
      activeFilters.priceMax = priceMax?.value || '';
      updateActiveFilters();
      applyFilters();
    }, 500);
    
    if (priceMin) {
      priceMin.addEventListener('input', debouncedPriceFilter);
    }
    
    if (priceMax) {
      priceMax.addEventListener('input', debouncedPriceFilter);
    }
    
    // In stock filter
    if (inStockOnly) {
      inStockOnly.addEventListener('change', (e) => {
        activeFilters.inStockOnly = (e.target as HTMLInputElement).checked;
        updateActiveFilters();
        applyFilters();
      });
    }
    
    // Clear all filters
    if (clearFiltersBtn) {
      clearFiltersBtn.addEventListener('click', () => {
        // Reset all filter inputs
        categoryFilters.forEach(input => input.checked = false);
        tagFilters.forEach(input => input.checked = false);
        specialFilters.forEach(input => input.checked = false);
        if (priceSort) priceSort.value = '';
        if (priceMin) priceMin.value = '';
        if (priceMax) priceMax.value = '';
        if (inStockOnly) inStockOnly.checked = false;
        
        // Reset filter state
        activeFilters = {
          categories: [],
          tags: [],
          special: [],
          priceSort: '',
          priceMin: '',
          priceMax: '',
          inStockOnly: false
        };
        
        updateActiveFilters();
        applyFilters();
      });
    }
    
    // Update results count when filters change
    document.addEventListener('filtersChanged', (e: any) => {
      // This will be handled by the product grid component
      console.log('Filters changed:', e.detail);
    });
  });
</script>