---
import { SITE_CONFIG, FOOTER_LINKS, WOMEN_EMPOWERMENT, ATMANIRBHAR_MESSAGING } from '@/utils/constants';

const currentYear = new Date().getFullYear();
---

<footer class="bg-gradient-to-br from-neutral-50 via-saffron-25 to-emerald-25 dark:bg-gradient-to-br dark:from-neutral-900 dark:via-neutral-900 dark:to-neutral-800 border-t-4 border-gradient-to-r from-saffron-500 to-emerald-500">
  <!-- Indian flag accent -->
  <div class="h-2 bg-gradient-to-r from-saffron-500 via-white to-emerald-500"></div>
  
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Women Empowerment Banner -->
    <div class="bg-white/85 backdrop-blur-sm rounded-2xl p-6 mb-12 border border-saffron-200 shadow-lg">
      <div class="text-center">
        <h3 class="text-2xl font-decorative font-bold text-saffron-800 mb-3">
          👩‍🎨 {WOMEN_EMPOWERMENT.tagline} 👩‍🎨
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-6">
          {Object.entries(WOMEN_EMPOWERMENT.stats).map(([_, stat]) => (
            <div class="text-center">
              <div class="text-lg sm:text-xl font-bold text-emerald-800">{stat.split(' ')[0]}</div>
              <div class="text-xs text-neutral-700 font-medium">{stat.split(' ').slice(1).join(' ')}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand Section -->
      <div class="lg:col-span-2">
        <div class="flex items-center space-x-3 text-2xl font-decorative font-bold mb-6">
          <!-- Enhanced logo with Indian elements -->
          <div class="relative">
            <svg class="w-10 h-10 text-saffron-600" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2L2 7v10c0 5.55 3.84 9.739 9 11 5.16-1.261 9-5.45 9-11V7l-10-5z"/>
            </svg>
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="text-xs text-white font-bold">ॐ</span>
            </div>
          </div>
          <div class="flex flex-col">
            <span class="text-saffron-600 leading-tight">{SITE_CONFIG.STORE_NAME}</span>
            <span class="text-sm text-emerald-600 font-hindi leading-none">
              {SITE_CONFIG.TAGLINE}
            </span>
          </div>
        </div>
        
        <p class="text-neutral-800 dark:text-neutral-200 mb-6 max-w-md leading-relaxed font-medium">
          {SITE_CONFIG.DESCRIPTION}
        </p>
        
        <!-- Brand values as badges -->
        <div class="flex flex-wrap gap-2 mb-6">
          <span class="inline-flex items-center px-3 py-1 bg-saffron-100 text-saffron-800 rounded-full text-xs font-medium">
            🇮🇳 Made in India
          </span>
          <span class="inline-flex items-center px-3 py-1 bg-emerald-100 text-emerald-800 rounded-full text-xs font-medium">
            👩‍🎨 Women Owned
          </span>
          <span class="inline-flex items-center px-3 py-1 bg-turmeric-100 text-turmeric-800 rounded-full text-xs font-medium">
            🌱 Sustainable
          </span>
        </div>
        
        <!-- Social Links with Indian styling -->
        <div class="flex space-x-4">
          <a 
            href={`https://instagram.com/${SITE_CONFIG.INSTAGRAM.replace('@', '')}`} 
            target="_blank" 
            rel="noopener noreferrer"
            class="p-3 bg-white/50 rounded-full text-saffron-600 hover:text-white hover:bg-saffron-600 transition-all duration-300 shadow-md hover:shadow-lg"
            aria-label="Follow us on Instagram"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 6.62 5.367 11.987 11.988 11.987 6.62 0 11.987-5.367 11.987-11.987C24.014 5.367 18.637.001 12.017.001zm5.765 18.462c-.728.988-1.798 1.798-3.187 2.412-1.464.649-3.043.974-4.699.974-1.656 0-3.235-.325-4.699-.974-1.389-.614-2.459-1.424-3.187-2.412-.728-.988-1.296-2.13-1.687-3.398-.364-1.182-.546-2.396-.546-3.623s.182-2.441.546-3.623c.391-1.268.959-2.41 1.687-3.398.728-.988 1.798-1.798 3.187-2.412C8.782.675 10.361.35 12.017.35s3.235.325 4.699.974c1.389.614 2.459 1.424 3.187 2.412.728.988 1.296 2.13 1.687 3.398.364 1.182.546 2.396.546 3.623s-.182 2.441-.546 3.623c-.391 1.268-.959 2.41-1.687 3.398z"/>
              <path d="M12.017 5.351c-3.667 0-6.636 2.969-6.636 6.636s2.969 6.636 6.636 6.636 6.636-2.969 6.636-6.636-2.969-6.636-6.636-6.636zm0 10.942c-2.373 0-4.306-1.933-4.306-4.306s1.933-4.306 4.306-4.306 4.306 1.933 4.306 4.306-1.933 4.306-4.306 4.306z"/>
              <circle cx="18.651" cy="5.351" r="1.564"/>
            </svg>
          </a>
          
          <a 
            href={`https://wa.me/${SITE_CONFIG.WHATSAPP_NUMBER_INTL.replace('+', '')}`} 
            target="_blank" 
            rel="noopener noreferrer"
            class="p-3 bg-white/50 rounded-full text-emerald-600 hover:text-white hover:bg-emerald-600 transition-all duration-300 shadow-md hover:shadow-lg"
            aria-label="Contact us on WhatsApp"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.570-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893A11.821 11.821 0 0020.465 3.488"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Shop by Indian Traditions -->
      <div>
        <h3 class="text-lg font-decorative font-bold text-saffron-800 mb-4 flex items-center">
          <span class="mr-2">🛍️</span> Shop by Tradition
        </h3>
        <ul class="space-y-3">
          <li>
            <a href="/category/festive-decor" class="text-neutral-800 dark:text-neutral-200 hover:text-saffron-700 transition-colors text-sm flex items-center font-medium">
              <span class="mr-2">🪔</span> Festive Decor
            </a>
          </li>
          <li>
            <a href="/category/home-decor" class="text-neutral-800 dark:text-neutral-200 hover:text-saffron-700 transition-colors text-sm flex items-center font-medium">
              <span class="mr-2">🏺</span> Home Decor
            </a>
          </li>
          <li>
            <a href="/category/pottery-ceramics" class="text-neutral-800 dark:text-neutral-200 hover:text-saffron-700 transition-colors text-sm flex items-center font-medium">
              <span class="mr-2">🏺</span> Pottery & Ceramics
            </a>
          </li>
          <li>
            <a href="/category/textiles-fabrics" class="text-neutral-800 dark:text-neutral-200 hover:text-saffron-700 transition-colors text-sm flex items-center font-medium">
              <span class="mr-2">🧵</span> Textiles & Fabrics
            </a>
          </li>
        </ul>
      </div>

      <!-- About -->
      <div>
        <h3 class="text-lg font-decorative font-bold text-emerald-800 mb-4 flex items-center">
          <span class="mr-2">🏛️</span> Our Mission
        </h3>
        <ul class="space-y-3">
          <li>
            <a href="/about" class="text-neutral-800 dark:text-neutral-200 hover:text-emerald-700 transition-colors text-sm flex items-center font-medium">
              <span class="mr-2">📖</span> Our Story
            </a>
          </li>
          <li>
            <a href="/contact" class="text-neutral-800 dark:text-neutral-200 hover:text-emerald-700 transition-colors text-sm flex items-center font-medium">
              <span class="mr-2">📞</span> Contact Us
            </a>
          </li>
          <li>
            <span class="text-neutral-800 dark:text-neutral-200 text-sm flex items-center font-medium">
              <span class="mr-2">🌱</span> Sustainable Crafts
            </span>
          </li>
          <li>
            <span class="text-neutral-800 dark:text-neutral-200 text-sm flex items-center font-medium">
              <span class="mr-2">👩‍🎨</span> Women Artisans
            </span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Atmanirbhar Bharat Section -->
    <div class="mt-12 pt-8 border-t-2 border-gradient-to-r from-saffron-300 to-emerald-300">
      <div class="bg-white/85 backdrop-blur-sm rounded-2xl p-6 border border-emerald-200 shadow-md">
        <div class="text-center">
          <h3 class="text-2xl font-decorative font-bold text-emerald-800 mb-3 font-hindi">
            🇮🇳 {ATMANIRBHAR_MESSAGING.title} 🇮🇳
          </h3>
          <p class="text-lg text-neutral-800 mb-4 font-hindi font-semibold">
            हर खरीदारी से मजबूत बने भारत | {ATMANIRBHAR_MESSAGING.subtitle}
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-left">
            {ATMANIRBHAR_MESSAGING.benefits.map((benefit) => (
              <div class="flex items-start">
                <span class="text-emerald-600 text-lg mr-3">🏛️</span>
                <span class="text-sm text-neutral-800 font-medium">{benefit}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Newsletter Signup with Indian Styling -->
    <div class="mt-12 pt-8 border-t border-neutral-200 dark:border-neutral-700">
      <div class="max-w-lg mx-auto text-center">
        <h3 class="text-xl font-decorative font-bold text-saffron-800 mb-3">
          🌸 Join Our Community 🌸
        </h3>
        <p class="text-neutral-700 dark:text-neutral-300 text-sm mb-6 font-medium">
          Get updates on new artisan products and stories of women empowerment.
        </p>
        
        <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input 
            type="email" 
            placeholder="Enter your email" 
            class="flex-1 px-4 py-3 border-2 border-saffron-200 dark:border-neutral-600 rounded-xl bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 placeholder-neutral-500 text-sm focus:outline-none focus:ring-2 focus:ring-saffron-500 focus:border-saffron-400 transition-all"
          />
          <button 
            type="submit" 
            class="px-6 py-3 bg-gradient-to-r from-saffron-600 to-emerald-600 text-white text-sm font-medium rounded-xl hover:from-saffron-700 hover:to-emerald-700 focus:outline-none focus:ring-2 focus:ring-saffron-500 focus:ring-offset-2 transition-all duration-300 shadow-lg hover:shadow-xl"
          >
            Subscribe 💌
          </button>
        </form>
      </div>
    </div>

    <!-- Bottom Footer with Indian Pride -->
    <div class="mt-12 pt-8 border-t-2 border-gradient-to-r from-saffron-200 to-emerald-200 flex flex-col sm:flex-row justify-between items-center">
      <div class="text-center sm:text-left">
        <p class="text-sm text-neutral-700 dark:text-neutral-300 mb-2 font-medium">
          &copy; {currentYear} {SITE_CONFIG.STORE_NAME}. All rights reserved.
        </p>
        <p class="text-xs text-neutral-600 dark:text-neutral-400 mb-2">
          Created with ❤️ by Pratik Bhuite
        </p>
        <p class="text-sm font-medium text-emerald-800 font-hindi">
          🇮🇳 गर्व से बना भारत में | Proudly Made in India
        </p>
        <p class="text-xs text-saffron-700 mt-1 font-medium">
          👩‍🎨 Supporting Women Entrepreneurs Across India
        </p>
      </div>
      
      <!-- Enhanced WhatsApp Quick Contact -->
      <div class="mt-6 sm:mt-0">
        <a 
          href={`https://wa.me/${SITE_CONFIG.WHATSAPP_NUMBER_INTL.replace('+', '')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-emerald-600 to-emerald-700 hover:from-emerald-700 hover:to-emerald-800 text-white text-sm font-medium rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1"
        >
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.570-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893A11.821 11.821 0 0020.465 3.488"/>
          </svg>
          Quick Chat 💬
        </a>
      </div>
    </div>
  </div>
</footer>