{
  "name": "artiistaa",
  "type": "module",
  "version": "1.0.0",
  "description": "A beautiful, mobile-first storefront for handmade art & craft brand Artiistaa",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "typecheck": "astro sync && tsc --noEmit",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.astro",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx,.astro --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "^6.1.8",
    "fuse.js": "^7.3.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.17",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "overrides": {
    "flatted": "3.4.2",
    "glob": {
      ".": "10.5.0",
      "minimatch": "9.0.7"
    },
    "mdast-util-to-hast": "13.2.1",
    "picomatch": "2.3.2",
    "rollup": "4.59.0"
  }
}
